# Caddy reverse proxy for the Urlaubs-Planer — terminates TLS on :443 and
# forwards to the Next app on 127.0.0.1:3000.
#
# Cert: Caddy's built-in *internal* CA issues a cert for the IP SAN 192.168.2.12.
# Clients must trust Caddy's local root once (run `caddy trust` on the server, and
# import that root on other devices) — otherwise they get a one-time TLS warning.
#
# See docs/DEPLOY.md → "Production hardening — TLS + next start" for the full runbook.

{
	# The host already runs Apache on :80. Caddy would normally bind :80 for an
	# HTTP->HTTPS redirect; disable that so the two don't fight over the port.
	auto_https disable_redirects
}

# Explicit https:// scheme => Caddy serves only on :443, no :80 vhost.
https://192.168.2.12 {
	tls internal
	# Forwards to the app and sets X-Forwarded-For / X-Forwarded-Proto, which the
	# app reads in clientIp(); Caddy is now the single trusted proxy hop.
	reverse_proxy 127.0.0.1:3000
}
