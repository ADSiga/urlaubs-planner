{
  "name": "kalender",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "watch": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "prod": "rmdir /s /q .next && next build && next start",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import ./lib/_tsresolve.mjs --test lib/*.test.ts"
  },
  "dependencies": {
    "next": "16.2.6",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "allowScripts": {
    "sqlite3@6.0.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
